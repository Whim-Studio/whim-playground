# Copy to .env and fill in for a real MySQL instance.
PORT=3000

# MySQL connection (mysql2). The app connects lazily; endpoints that need the DB
# fail with a clear 503 if these are unset/unreachable, so the skeleton still boots.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=mahjong
DB_PASSWORD=change-me
DB_NAME=tiwas_mahjong
DB_CONNECTION_LIMIT=10

# Set to "memory" to run the in-process demo repository instead of MySQL.
# The production target is "mysql"; "memory" exists only so the skeleton is
# playable/testable without a database provisioned.
PERSISTENCE_DRIVER=mysql
